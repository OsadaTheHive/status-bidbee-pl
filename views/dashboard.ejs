<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="refresh" content="60">
<title>UL OS Status</title>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin: 0; padding: 20px;
    background: #0d0d0d; color: #e8e8e8;
    font-size: 13px; line-height: 1.5;
  }
  h1 {
    font-size: 18px; font-weight: 500; margin: 0 0 4px;
    background: linear-gradient(135deg, #B8A9E8 0%, #7DD4A3 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .meta { color: #888; font-size: 11px; margin-bottom: 24px; }
  .meta a { color: #B8A9E8; text-decoration: none; font-weight: 500; }
  .meta a:hover { text-decoration: underline; }
  section { background: #1a1a1a; border-radius: 8px; padding: 14px 18px; margin-bottom: 14px; }
  h2 { font-size: 13px; font-weight: 500; margin: 0 0 10px; color: #aaa; text-transform: uppercase; letter-spacing: 0.5px; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  th, td { padding: 6px 10px; text-align: left; border-bottom: 1px solid #2a2a2a; }
  th { color: #888; font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: 0.3px; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; color: #c0c0c0; }
  .ok { color: #7DD4A3; }
  .warn { color: #F2D06B; }
  .err { color: #F4A76C; }
  .badge { display: inline-block; font-size: 10px; padding: 2px 7px; border-radius: 4px; background: #2a2a2a; }
  .badge.ok { background: rgba(125, 212, 163, 0.15); color: #7DD4A3; }
  .badge.warn { background: rgba(242, 208, 107, 0.15); color: #F2D06B; }
  .badge.err { background: rgba(244, 167, 108, 0.15); color: #F4A76C; }
  .err-msg { color: #F4A76C; font-size: 11px; font-style: italic; padding: 8px 0; }
  code { font-family: 'SF Mono', Consolas, monospace; font-size: 11px; color: #aaa; }
  a { color: #B8A9E8; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .embed-bar {
    background: #0d0d0d; border-radius: 4px; height: 8px; overflow: hidden;
    margin: 8px 0 6px; border: 1px solid #2a2a2a;
  }
  .embed-fill {
    height: 100%; background: linear-gradient(90deg, #7DD4A3 0%, #B8A9E8 100%);
    transition: width 0.3s;
  }
  .embed-stats { display: flex; gap: 18px; font-size: 12px; color: #aaa; flex-wrap: wrap; }
  .embed-stats b { color: #e8e8e8; font-weight: 500; }
</style>
</head>
<body>
<h1>UL OS Status</h1>
<p class="meta">Generated <%= status.generated_at %> · auto-refresh 60s · <a href="/search">🔍 Search</a> · <a href="/api/status.json">JSON</a></p>

<% if (status.embeddings && !status.embeddings.error) { %>
<section>
  <h2>Embeddings coverage · pgvector + Voyage AI</h2>
  <div class="embed-bar">
    <div class="embed-fill" style="width: <%= status.embeddings.coveragePct %>%"></div>
  </div>
  <div class="embed-stats">
    <span><b><%= status.embeddings.coveragePct %>%</b> coverage</span>
    <span><b><%= Number(status.embeddings.embedded).toLocaleString('pl-PL') %></b> embedded</span>
    <span><b><%= Number(status.embeddings.pending).toLocaleString('pl-PL') %></b> pending</span>
    <span><b><%= Number(status.embeddings.total).toLocaleString('pl-PL') %></b> total</span>
    <% if (status.embeddings.lastEmbeddedAt) { %>
      <span>last: <%= new Date(status.embeddings.lastEmbeddedAt).toLocaleString('pl-PL') %></span>
    <% } %>
  </div>
</section>
<% } %>

<section>
  <h2>Coolify Apps</h2>
  <% if (status.coolify.error) { %>
    <p class="err-msg"><%= status.coolify.error %></p>
  <% } else { %>
    <table>
      <thead><tr><th>Name</th><th>UUID</th><th>FQDN</th><th>Status</th></tr></thead>
      <tbody>
        <% status.coolify.items.forEach(app => { %>
          <tr>
            <td><%= app.name %></td>
            <td><code><%= app.uuid %></code></td>
            <td><%= (app.fqdn || '').split(',')[0] %></td>
            <td>
              <% if (app.status.includes('healthy')) { %><span class="badge ok"><%= app.status %></span>
              <% } else if (app.status.includes('unhealthy')) { %><span class="badge err"><%= app.status %></span>
              <% } else { %><span class="badge warn"><%= app.status %></span><% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>Postgres — ulos_knowledge (UL OS scope)</h2>
  <% if (status.postgres.error) { %>
    <p class="err-msg"><%= status.postgres.error %></p>
  <% } else { %>
    <table>
      <thead><tr><th>Table</th><th class="num">Rows</th></tr></thead>
      <tbody>
        <% status.postgres.items.forEach(t => { %>
          <tr><td><%= t.table_name %></td><td class="num"><%= Number(t.row_count).toLocaleString('pl-PL') %></td></tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>SQLite — cms.osadathehive.pl (legacy + BEEZhub)</h2>
  <% if (status.sqlite.error) { %>
    <p class="err-msg"><%= status.sqlite.error %></p>
  <% } else { %>
    <table>
      <thead><tr><th>Collection</th><th class="num">Count</th></tr></thead>
      <tbody>
        <% status.sqlite.items.forEach(t => { %>
          <tr><td><%= t.collection %></td><td class="num"><%= typeof t.count === 'number' ? t.count.toLocaleString('pl-PL') : t.count %></td></tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>Recent Vault Commits</h2>
  <% if (status.vault.error) { %>
    <p class="err-msg"><%= status.vault.error %></p>
  <% } else { %>
    <table>
      <thead><tr><th>SHA</th><th>Message</th><th>Author</th><th>When</th></tr></thead>
      <tbody>
        <% status.vault.items.forEach(c => { %>
          <tr>
            <td><code><%= c.sha %></code></td>
            <td><%= c.message %></td>
            <td><%= c.author %></td>
            <td><%= new Date(c.date).toLocaleString('pl-PL') %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

</body>
</html>
